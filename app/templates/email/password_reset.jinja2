{% extends "email/base.jinja2" %}
{% block email_title %}Password reset · Broke{% endblock %}
{% block preheader %}Reset your Broke password — this link expires in 24 hours.{% endblock %}
{% block content %}
<h1 style="margin:0 0 18px;font-family: {{ brand.heading_font }};font-size: 22px;font-weight: 600;color: #111827;line-height: 1.25;">
  Password reset
</h1>
<p style="margin:0 0 16px;">Hello {{ display_name }},</p>
<p style="margin:0 0 20px;color: #374151;">
  You asked to reset your password. Use the button below to choose a new one. This link is only valid for a short time.
</p>
<p style="margin:0 0 24px;">
  <a href="{{ reset_link }}"
     style="display:inline-block;background-color: {{ brand.logo_blue }};color: #ffffff;font-family: {{ brand.body_font }};font-size: 16px;font-weight: 600;text-decoration: none;padding: 12px 22px;border-radius: 6px;line-height: 1.2;">
    Reset password
  </a>
</p>
<p style="margin:0 0 12px;font-size: 14px;color: #6b7280;">
  If the button does not work, paste this URL into your browser:<br>
  <a href="{{ reset_link }}" style="color: {{ brand.logo_blue }};word-break: break-all;">{{ reset_link }}</a>
</p>
<p style="margin:0;font-size: 14px;color: {{ brand.secondary }};">
  If you did not request a reset, you can safely ignore this email.
</p>
{% endblock %}
