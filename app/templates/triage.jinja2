{% extends "dashboard.jinja2" %}

{% block title %}{{ ticket_page_title or 'Intake Inbox' }} | Broke{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/modal.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/triage_split.css') }}">
{% endblock %}

{% block content %}
<h1 style="margin-bottom: 0.2rem;">{{ ticket_page_title or 'Intake Inbox' }}</h1>
<p class="triage-page-subtitle">Capture issues quickly and route them without losing context.</p>

<div class="triage-layout">
    <section id="triage-intake-panel" class="triage-primary-panel">
        <div id="triage-chat-panel" class="card triage-intake-card">
            <div class="triage-intake-header">
                <div class="triage-intake-heading-row">
                    <h3><i class="ph ph-magic-wand"></i> {% if ai_intake_enabled %}AI Intake{% else %}Quick Intake{% endif %}</h3>
                    <span class="triage-mode-pill">
                        <i class="ph {% if ai_intake_enabled %}ph-brain{% else %}ph-chat-circle-text{% endif %}"></i>
                        {% if ai_intake_enabled %}AI Enabled{% else %}Guided Mode{% endif %}
                    </span>
                </div>
                <p>
                    {% if ai_intake_enabled %}
                    Describe the issue naturally. The assistant will gather details and prepare the ticket.
                    {% else %}
                    AI is not configured. Use guided chat to capture summary, impact, context, and routing.
                    {% endif %}
                </p>
            </div>
            <div class="triage-chat-tools triage-chat-tools-single">
                <button type="button" id="triage-chat-reset" class="triage-chat-reset"><i class="ph ph-arrow-counter-clockwise"></i> Reset</button>
            </div>
            <div id="triage-chat-thread" class="triage-chat-thread" aria-live="polite"></div>
            <div class="triage-chat-composer">
                <textarea id="triage-chat-input" class="form-input" rows="3" placeholder="Describe the problem. Press Enter to send, Shift+Enter for new line."></textarea>
                <div class="triage-chat-send-row">
                    <button type="button" id="triage-chat-send" class="btn btn-primary"><i class="ph ph-paper-plane-tilt"></i> Send</button>
                </div>
            </div>
            <p class="triage-chat-help"><i class="ph ph-sparkle"></i> The assistant drafts title, priority, and project routing while you chat.</p>
        </div>
    </section>

    <section id="triage-inbox-panel" class="triage-secondary-panel">
        <div class="card triage-inbox-shell">
            <div class="triage-inbox-header">
                <h3 style="margin: 0;"><i class="ph ph-stack"></i> Inbox Routing Queue</h3>
                <span id="triage-inbox-count" class="triage-inbox-count">{{ tickets|length }}</span>
            </div>
            <div id="triage-inbox-list" class="triage-inbox-list">
                {% for ticket in tickets %}
                <article class="triage-inbox-row" data-triage-ticket-id="{{ ticket.id }}">
                    <div class="triage-inbox-row-main">
                        <h4 class="triage-ticket-title">{{ ticket.title }}</h4>
                        <p class="triage-ticket-meta"><span class="triage-ticket-id"><i class="ph ph-hash"></i> {{ ticket.id }}</span> · <i class="ph ph-flag-pennant"></i> Priority {{ ticket.priority }} · <i class="ph ph-clock"></i> {{ ticket.created_at }}</p>
                    </div>
                    <div class="triage-inbox-row-actions">
                        <div class="triage-inbox-toolbar">
                            <a class="btn btn-secondary triage-view-ticket-btn" href="{{ request.script_root }}/tickets/{{ ticket.project }}/{{ ticket.id }}"><i class="ph ph-eye"></i> View</a>
                            <button type="button" class="btn btn-secondary triage-discard-btn" data-triage-ticket-id="{{ ticket.id }}" title="Remove from intake"><i class="ph ph-trash"></i> Discard</button>
                        </div>
                        <div class="triage-route-buttons" role="group" aria-label="Route {{ ticket.id }} to project">
                            {% for proj in projects %}
                            <button type="button" class="btn btn-secondary triage-route-project-btn" data-project-id="{{ proj.id }}">{{ proj.id }}</button>
                            {% endfor %}
                        </div>
                    </div>
                </article>
                {% endfor %}
            </div>
            <div id="triage-empty-state" class="triage-empty-state {% if tickets|length > 0 %}triage-hidden{% endif %}">
                <p style="margin: 0; color: var(--text-secondary);">No tickets currently in intake.</p>
            </div>
        </div>
    </section>
</div>
{% endblock %}

{% block path %}
    <a href="{{ request.script_root }}/intake"><i class="ph ph-tray"></i> Intake</a>
    {% if project %}
    <i class="ph ph-caret-right"></i>
    <a href="{{ request.script_root }}/intake/{{ project.id }}"><i class="{{ project.icon }}"></i> {{ project.name }}</a>
    {% endif %}
{% endblock %}

{% block scripts %}
    <script>
        window.triageData = {
            tickets: [
                {% for ticket in tickets %}
                {
                    id: {{ ticket.id | tojson }},
                    title: {{ ticket.title | tojson }},
                    description: {{ ticket.description | tojson }},
                    priority: {{ ticket.priority | tojson }},
                    project: {{ ticket.project | tojson }},
                    createdAt: {{ ticket.created_at | tojson }}
                },
                {% endfor %}
            ],
            projects: [
                {% for proj in projects %}
                { id: {{ proj.id | tojson }}, name: {{ proj.name | tojson }} },
                {% endfor %}
            ],
            endpoints: {
                intake: '/api/tickets/intake',
                chat: '/api/tickets/intake/ai/chat',
                commit: '/api/tickets/intake/ai/commit'
            },
            aiEnabled: {{ ai_intake_enabled | tojson }}
        };
    </script>
    <script src="{{ url_for('static', filename='js/triage_dashboard.js') }}"></script>
{% endblock %}
