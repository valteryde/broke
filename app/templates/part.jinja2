{% extends "dashboard.jinja2" %}

{% block title %}{{ part.name }} | Errors | Broke{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dropdown.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/lists.css') }}">
{% endblock %}

{% block path %}
    <a href="#" onclick="openUrlWithArgs('/errors'); return false;"><i class="ph ph-bug-beetle"></i> Errors</a>
    <i class="ph ph-caret-right"></i>
    <a href="#" onclick="openUrlWithArgs('/errors/{{ project.id }}'); return false;"><i class="{{ project.icon }}"></i> {{ project.name }}</a>
    <i class="ph ph-caret-right"></i>
    <span><i class="ph ph-puzzle-piece"></i> {{ part.name }}</span>
{% endblock %}

{% block content %}

<div class="part-errors-toolbar">
    <div class="part-errors-toolbar-text">
        <h1>{{ part.name }}</h1>
        <p class="part-errors-description">{{ part.description or 'No description provided.' }}</p>
    </div>
    {% if part_error_count > 0 %}
    <button type="button" class="btn btn-danger" id="delete-all-part-errors-btn" data-project-id="{{ project.id }}" data-part-id="{{ part.id }}" data-total-errors="{{ part_error_count }}" title="Permanently delete all errors in this part">
        <i class="ph ph-trash"></i> Delete all errors
    </button>
    {% endif %}
</div>

<div id="error-list"></div>

{% endblock %}

{% block scripts %}
    <script src="{{ url_for('static', filename='js/config.js') }}"></script>
    <script src="{{ url_for('static', filename='js/dropdown.js') }}"></script>
    <script src="{{ url_for('static', filename='js/lists.js') }}"></script>
    <script src="{{ url_for('static', filename='js/error_list.js') }}"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const errorList = new List('error-list', {
                ...ErrorListConfig,
                onUpdate: async (item, field, value) => {
                    if (field === 'status') {
                        try {
                            const response = await fetch(`/api/errors/${item.id}/status`, {
                                method: 'POST',
                                headers: {
                                    'Content-Type': 'application/json',
                                    'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
                                },
                                body: JSON.stringify({ status: value })
                            });

                            if (response.ok) {
                                item.status = value;
                                errorList.render();
                                if (window.showToast) showToast(`Error marked as ${value}`, 'success');
                            } else {
                                if (window.showToast) showToast('Failed to update error status', 'error');
                            }
                        } catch (error) {
                            console.error('Update error:', error);
                            if (window.showToast) showToast('Failed to update error status', 'error');
                        }
                    }
                },
                onDelete: async (item) => {
                    try {
                        const response = await fetch(`/api/errors/${item.id}`, {
                            method: 'DELETE'
                        });

                        if (response.ok) {
                            errorList.remove(item.id);
                            // Also show a toast if available, or just log
                            if (window.showToast) showToast('Error deleted', 'success');
                        } else {
                            if (window.showToast) showToast('Failed to delete error', 'error');
                        }
                    } catch (error) {
                        console.error('Delete error:', error);
                    }
                }
            });

            const errorListItems = [
                {% for error in error_groups %}
                {
                    id: '{{ error.id }}',
                    title: '{{ error.exception_type or "Error" }}',
                    description: '{{ error.exception_value | default("No message", true) | replace("'", "\\'") | replace("\n", " ") | truncate(200) }}',
                    icon: 'ph-warning-circle',
                    status: '{{ error.status }}',
                    environment: {{ ('"%s"' % error.environment) if error.environment else 'null' }},
                    release: {{ ('"%s"' % error.release) if error.release else 'null' }},
                    labels: [
                        {% if error.platform %}
                        { text: '{{ error.platform }}', color: '#3b82f6' },
                        {% endif %}
                        {% if error.environment %}
                        { text: '{{ error.environment }}', color: '#8b5cf6' },
                        {% endif %}
                        {% if error.release %}
                        { text: '{{ error.release }}', color: '#06b6d4' },
                        {% endif %}
                    ],
                    createdAt: {{ error.last_seen }} * 1000,
                    meta: '{{ error.event_count }} events',
                    onClick: () => { window.location.href = '/errors/{{ project.id }}/{{ part.id }}/{{ error.id }}'; }
                },
                {% endfor %}
            ];

            errorListItems.forEach(error => errorList.add(error));

            const deleteAllBtn = document.getElementById('delete-all-part-errors-btn');
            if (deleteAllBtn) {
                deleteAllBtn.addEventListener('click', async () => {
                    const total = parseInt(deleteAllBtn.getAttribute('data-total-errors') || '0', 10);
                    const label = total === 1 ? '1 error' : `${total} errors`;
                    if (!confirm(`Delete all ${label} in this part? This cannot be undone.`)) {
                        return;
                    }
                    const projectId = deleteAllBtn.getAttribute('data-project-id');
                    const partId = deleteAllBtn.getAttribute('data-part-id');
                    const csrf = document.querySelector('meta[name="csrf-token"]')?.content || '';
                    try {
                        const response = await fetch(
                            `/api/projects/${projectId}/parts/${partId}/errors`,
                            {
                                method: 'DELETE',
                                headers: csrf ? { 'X-CSRF-Token': csrf } : {}
                            }
                        );
                        if (!response.ok) {
                            if (window.showToast) showToast('Failed to delete all errors', 'error');
                            return;
                        }
                        errorList.elements = [];
                        errorList.applyFilters();
                        deleteAllBtn.remove();
                        if (window.showToast) showToast('All errors deleted', 'success');
                    } catch (err) {
                        console.error(err);
                        if (window.showToast) showToast('Failed to delete all errors', 'error');
                    }
                });
            }

            const errorListRoot = document.getElementById('error-list');
            if (errorListRoot) {
                errorListRoot.addEventListener('click', (event) => {
                    const button = event.target.closest('.error-inline-action');
                    if (!button) return;

                    const errorId = button.getAttribute('data-error-id');
                    const newStatus = button.getAttribute('data-status');
                    if (!errorId || !newStatus) return;

                    const item = errorList.elements.find((row) => String(row.id) === String(errorId));
                    if (!item) return;

                    errorList.handleUpdate(item, 'status', newStatus);
                });
            }
        });
    </script>

{% endblock %}
