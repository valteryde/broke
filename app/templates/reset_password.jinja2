{% extends "standalone.jinja2" %}

{% block title %}Reset Password | Broke{% endblock %}

{% block content %}

<!-- Decorative background elements -->
<div class="standalone-decoration standalone-decoration-1"></div>
<div class="standalone-decoration standalone-decoration-2"></div>

<div class="standalone-card">
    <div class="standalone-card-header">
        <h1>Set New Password</h1>
        <p>Enter your new password below</p>
    </div>
    
    <div class="standalone-card-body">
        <form method="POST" action="/reset-password/{{ token }}" class="standalone-form">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <div class="form-group">
                <label for="password">New Password</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    class="form-input" 
                    placeholder="Enter new password"
                    autocomplete="new-password"
                    autofocus
                    required
                >
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-submit">
                    Reset Password
                </button>
            </div>
        </form>
    </div>
</div>

{% endblock %}
