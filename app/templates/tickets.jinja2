{% extends "dashboard.jinja2" %}

{% block title %}{{ ticket_page_title or 'Tickets' }} | Broke{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dropdown.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/lists.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/board.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/modal.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/choices.js/public/assets/styles/choices.min.css">

    <script>
    (function initTicketViewPreference() {
        const url = new URL(window.location.href);
        const explicitView = url.searchParams.get('view');
        const savedView = localStorage.getItem('ticket_view_preference');
        const allowed = ['list', 'board'];
        if (explicitView && allowed.includes(explicitView)) {
            localStorage.setItem('ticket_view_preference', explicitView);
            return;
        }

        if (!explicitView && savedView && allowed.includes(savedView) && savedView !== '{{ ticket_view }}') {
            url.searchParams.set('view', savedView);
            window.location.replace(url.toString());
        }
    })();

    function setTicketView(view) {
        localStorage.setItem('ticket_view_preference', view);
        const url = new URL('{{ ticket_view_path }}', window.location.origin);
        url.searchParams.set('view', view);
        window.location.href = url.toString();
    }

    window.availableUsers = [
        {% for available_user in available_users %} 
        {
            id: '{{ available_user.username }}',
            username: '{{ available_user.username }}',
        },
        {% endfor %}
    ];

    window.availableLabels = [
        {% for available_label in available_labels %} 
        {
            id: '{{ available_label.name }}',
            name: '{{ available_label.name }}',
            color: '{{ available_label.color }}'
        },
        {% endfor %}
    ];

    </script>


{% endblock %}

{% block content %}

<h1 style="margin-bottom: 1rem;">{{ ticket_page_title or 'Tickets' }}</h1>

{% if page == 'triage' %}
<div class="card" style="margin-bottom: 1rem;">
    <p style="margin: 0; font-weight: 600;">Triage is your intake inbox.</p>
    <p style="margin: 0.35rem 0 0; color: var(--text-secondary);">
        Use <strong>Quick Intake</strong> to capture new work, then use <strong>Send Selected</strong> to assign a project and move the ticket into backlog.
    </p>
</div>
{% endif %}

{% if page != 'triage' %}
<div class="ticket-view-toggle" role="tablist" aria-label="Ticket view mode">
    <button class="ticket-view-toggle-btn {% if ticket_view == 'list' %}active{% endif %}" type="button" role="tab" aria-selected="{{ 'true' if ticket_view == 'list' else 'false' }}" onclick="setTicketView('list')">
        <i class="ph ph-list"></i>
        <span>List</span>
    </button>
    <button class="ticket-view-toggle-btn {% if ticket_view == 'board' %}active{% endif %}" type="button" role="tab" aria-selected="{{ 'true' if ticket_view == 'board' else 'false' }}" onclick="setTicketView('board')">
        <i class="ph ph-kanban"></i>
        <span>Board</span>
    </button>
</div>
{% endif %}

{% if page != 'triage' %}
<div class="project-tabs" id="project-tabs">
    <button class="project-tab {% if not project %}active{% endif %}" data-project="all" onclick="window.location.href = '{{ ticket_base_path or '/tickets' }}'">
        <i class="ph ph-squares-four"></i> All
    </button>
    <!-- Project tabs will be populated dynamically -->

    {% for proj in projects %}
    <button class="project-tab {% if project and proj.id == project.id %}active{% endif %}" data-project="{{ proj.id }}" onclick="window.location.href = '{{ ticket_base_path or '/tickets' }}/{{ proj.id }}'">
        <i class="{{ proj.icon }}"></i> {{ proj.name }}
    </button>
    {% endfor %}

</div>
{% endif %}

{% if ticket_view == 'board' %}
<div id="ticket-board" class="ticket-board"></div>
{% else %}
<div id="ticket-list"></div>
{% endif %}

{% endblock %}

{% block path %}
    {% if page == 'triage' %}
    <a href="/triage"><i class="ph ph-tray"></i> Triage</a> {% if project %} <i class="ph ph-caret-right"></i> <a href="/triage/{{ project.id }}"><i class="{{ project.icon }}"></i> {{ project.name }}</a> {% endif %}
    {% else %}
    <a href="/tickets"><i class="ph ph-ticket"></i> Tickets</a> {% if project %} <i class="ph ph-caret-right"></i> <a href="/tickets/{{ project.id }}"><i class="{{ project.icon }}"></i> {{ project.name }}</a> {% endif %}
    {% endif %}
{% endblock %}

{% block scripts %}

    <script src="https://cdn.jsdelivr.net/npm/choices.js/public/assets/scripts/choices.min.js"></script>
    <script src="{{ url_for('static', filename='js/config.js') }}"></script>
    <script src="{{ url_for('static', filename='js/dropdown.js') }}"></script>
    <script src="{{ url_for('static', filename='js/ticket_list.js') }}"></script>
    <script src="{{ url_for('static', filename='js/board.js') }}"></script>
    <script src="{{ url_for('static', filename='js/lists.js') }}"></script>
    <script src="{{ url_for('static', filename='js/modal.js') }}"></script>
    <script src="{{ url_for('static', filename='js/list_modal.js') }}"></script>
    
    
    <script>
        // Available projects for ticket creation modal
        window.availableProjects = [
            {% for proj in projects %}
            {
                id: '{{ proj.id }}',
                name: '{{ proj.name }}',
                icon: '{{ proj.icon }}',
                color: '{{ proj.color }}'
            },
            {% endfor %}
        ];

        // Available options for dropdowns (globals for List/Shortcuts to use)
        window.availableUsers = [
            {% for available_user in available_users %} 
            {
                id: '{{ available_user.username }}',
                username: '{{ available_user.username }}',
            },
            {% endfor %}
        ];
        
        window.availableLabels = [
            {% for available_label in available_labels %}
            {
                id: '{{ available_label.name }}',
                name: '{{ available_label.name }}',
                color: '{{ available_label.color }}'
            },
            {% endfor %}
        ];

        // Show create ticket modal
        function showCreateTicketModal() {
            if ('{{ page }}' === 'triage') {
                window.selectedProjectId = null;
                createTicket();
                return;
            }

            let selectedProject = {% if project %}'{{ project.id }}'{% else %}null{% endif %};
            
            const projectItems = window.availableProjects.map(proj => `
                <div class="modal-project-item ${selectedProject === proj.id ? 'selected' : ''}" 
                     data-project-id="${proj.id}"
                     onclick="selectProject('${proj.id}')">
                    <i class="${proj.icon}"></i>
                    <span class="modal-project-item-name">${proj.name}</span>
                    <span class="modal-project-item-id">${proj.id}</span>
                </div>
            `).join('');
            
            Modal.show('Create New Ticket', `
                <div class="form-group">
                    <label>Select Project</label>
                    <div class="modal-project-list" id="project-list">
                        ${projectItems}
                    </div>
                </div>
                <div class="form-actions">
                    <button type="button" class="btn btn-secondary" onclick="Modal.close()">Cancel</button>
                    <button type="button" class="btn btn-primary" id="create-ticket-btn" onclick="createTicket()">
                        Create Ticket
                    </button>
                </div>
            `);
            
            // Store selected project in window for access by createTicket
            window.selectedProjectId = selectedProject;
            updateCreateButton();
        }

        async function persistTicketFieldUpdate(ticketId, field, value) {
            const response = await fetch(`/api/tickets/${ticketId}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ field, value })
            });

            if (!response.ok) {
                let message = 'Unknown error';
                try {
                    const error = await response.json();
                    message = error.error || message;
                } catch (_) {
                    // Keep fallback message.
                }
                throw new Error(message);
            }
        }

        async function sendTicketToProject(item, projectId) {
            await persistTicketFieldUpdate(item.id, 'project', projectId);
            await persistTicketFieldUpdate(item.id, 'status', 'backlog');
            item.project = projectId;
            item.status = 'backlog';
        }

        function openSendSelectedModal(listInstance) {
            if (!window.availableProjects || window.availableProjects.length === 0) {
                showToast('No projects available', 'error');
                return;
            }

            const selected = listInstance.selectedIndex >= 0 ? listInstance.renderedItems[listInstance.selectedIndex] : null;
            if (!selected || !selected.element) {
                showToast('Select a triage ticket first', 'error');
                return;
            }

            const item = selected.element;
            new ListModal({
                title: `Send ${item.id} to Project`,
                items: window.availableProjects.map(project => ({
                    label: project.name,
                    value: project.id,
                    icon: project.icon
                })),
                onSelect: async (selectedProject) => {
                    try {
                        await sendTicketToProject(item, selectedProject.value);
                        listInstance.applyFilters();
                        showToast(`Sent ${item.id} to ${selectedProject.label}`, 'success');
                    } catch (error) {
                        showToast(error.message || 'Failed to send ticket', 'error');
                    }
                }
            }).show();
        }
        
        // Select project in modal
        function selectProject(projectId) {
            window.selectedProjectId = projectId;
            
            // Update UI
            document.querySelectorAll('.modal-project-item').forEach(item => {
                item.classList.toggle('selected', item.dataset.projectId === projectId);
            });
            
            updateCreateButton();
        }
        
        // Update create button state
        function updateCreateButton() {
            const btn = document.getElementById('create-ticket-btn');
            if (btn) {
                btn.disabled = !window.selectedProjectId;
            }
        }
        
        // Create ticket and redirect
        async function createTicket() {
            const isTriagePage = '{{ page }}' === 'triage';
            if (!isTriagePage && !window.selectedProjectId) return;
            
            const btn = document.getElementById('create-ticket-btn');
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<i class="ph ph-circle-notch" style="animation: spin 1s linear infinite;"></i> Creating...';
            }
            
            try {
                const endpoint = '{{ ticket_create_endpoint or '/api/tickets' }}';
                const defaultStatus = '{{ ticket_create_status or 'backlog' }}';
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        project: isTriagePage ? null : window.selectedProjectId,
                        title: '',
                        status: defaultStatus,
                        priority: 'medium'
                    })
                });
                
                if (response.ok) {
                    const data = await response.json();
                    Modal.close();
                    // Redirect to new ticket
                    if ('{{ page }}' === 'triage') {
                        window.location.href = '/triage';
                    } else {
                        window.location.href = `/tickets/${data.ticket.project}/${data.ticket.id}`;
                    }
                } else {
                    const error = await response.json();
                    alert('Failed to create ticket: ' + (error.error || 'Unknown error'));
                    if (btn) {
                        btn.disabled = false;
                        btn.innerHTML = 'Create Ticket';
                    }
                }
            } catch (error) {
                console.error('Create ticket error:', error);
                alert('Failed to create ticket');
                if (btn) {
                    btn.disabled = false;
                    btn.innerHTML = 'Create Ticket';
                }
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            const tickets = [
                {% for ticket in tickets %}
                {
                    id: '{{ ticket.id }}',
                    title: '{{ ticket.title.replace("'", "\\'") | safe }}',
                    description: '{{ ticket.description | safe }}',
                    icon: {% if ticket.priority == "urgent" %}'ph ph-warning'{% else %} 'ph ph-cell-signal-{{ "high" if ticket.priority == "high" else "medium" if ticket.priority == "medium" else "low" if ticket.priority == "low" else "none" }}'{% endif %},
                    status: '{{ ticket.status | default("backlog") }}',
                    urgency: '{{ ticket.priority }}',
                    labels: [
                        {% for label in ticket.labels %}
                        {text: '{{ label.name }}', color: '{{ label.color }}'},
                        {% endfor %}
                    ],
                    assignees: [
                        {% for assignee in ticket.assignees %}
                        '{{ assignee }}',
                        {% endfor %}
                    ],
                    createdAt: '{{ ticket.created_at }}',
                    project: '{{ ticket.project }}',
                    onClick: () => { window.location.href = '/tickets/{{ ticket.project }}/{{ ticket.id }}'; }
                },
                {% endfor %}
            ];

            const ticketView = '{{ ticket_view }}';

            if (ticketView === 'board') {
                TicketBoard.init('ticket-board', tickets, {
                    async onMove(ticketId, newStatus) {
                        const response = await fetch(`/api/tickets/${ticketId}`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ field: 'status', value: newStatus })
                        });

                        if (!response.ok) {
                            throw new Error('Failed to update ticket status');
                        }
                    },
                    onCardClick(ticket) {
                        window.location.href = `/tickets/${ticket.project}/${ticket.id}`;
                    }
                });
                return;
            }

            const isTriagePage = '{{ page }}' === 'triage';
            const ticketList = new List('ticket-list', {
                ...TicketListConfig,
                syncUrlState: false,
                getInitialState: loadTicketListState,
                onStateChange: saveTicketListState,
                onCreateLabel: isTriagePage ? 'Quick Intake' : 'Add Ticket',
                onCreate: () => {
                    showCreateTicketModal();
                },
                onClearFilters: (list) => {
                    list.clearAllFilters();
                    const searchInput = document.querySelector('.list-search-input');
                    if (searchInput) {
                        searchInput.value = '';
                    }
                    showToast('Filters cleared', 'success');
                },
                onClearFiltersLabel: 'Clear Filters',
                onUpdate: async (item, field, value, isToggle) => {
                    let backendField = field;
                    let backendValue = value;

                    if (field === 'priority') backendField = 'priority';

                    if (field === 'assignees') {
                        backendField = 'assignees';
                        backendValue = item.assignees.map(u => {
                            const user = window.availableUsers.find(au => au.username === u);
                            return user ? { username: user.username, id: user.id } : { username: u };
                        });
                    }

                    if (field === 'labels') {
                        backendValue = item.labels.map(l => ({ name: l.text, color: l.color }));
                    }

                    try {
                        const response = await fetch(`/api/tickets/${item.id}`, {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ field: backendField, value: backendValue })
                        });

                        if (!response.ok) {
                            showToast('Failed to save changes', 'error');
                        } else {
                            showToast('Updated ' + field, 'success');
                        }
                    } catch (error) {
                        console.error('Save error:', error);
                        showToast('Error saving changes', 'error');
                    }
                },
                onDelete: async (item) => {
                    try {
                        const response = await fetch(`/api/tickets/${item.id}`, {
                            method: 'DELETE'
                        });

                        if (response.ok) {
                            ticketList.remove(item.id);
                            showToast('Ticket deleted', 'success');
                        } else {
                            showToast('Failed to delete ticket', 'error');
                        }
                    } catch (error) {
                        console.error('Delete error:', error);
                        showToast('Error deleting ticket', 'error');
                    }
                }
            });

            window.ticketList = ticketList;

            if (isTriagePage) {
                const filterRow = ticketList.wrapper ? ticketList.wrapper.querySelector('.list-filter-options') : null;
                if (filterRow) {
                    const sendButton = document.createElement('button');
                    sendButton.className = 'list-create-btn';
                    sendButton.innerHTML = '<span><i class="ph ph-paper-plane-tilt"></i> Send Selected</span>';
                    sendButton.addEventListener('click', () => openSendSelectedModal(ticketList));
                    filterRow.appendChild(sendButton);
                }
            }

            tickets.forEach(ticket => ticketList.add(ticket));

        });
    </script>

{% endblock %}
