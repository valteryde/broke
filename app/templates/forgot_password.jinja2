{% extends "standalone.jinja2" %}

{% block title %}Forgot Password | Broke{% endblock %}

{% block content %}

<!-- Decorative background elements -->
<div class="standalone-decoration standalone-decoration-1"></div>
<div class="standalone-decoration standalone-decoration-2"></div>

<div class="standalone-card">
    <div class="standalone-card-header">
        <h1>Forgot Password</h1>
        <p>Enter your email address to recover your account</p>
    </div>
    
    <div class="standalone-card-body">
        <form method="POST" action="/forgot-password" class="standalone-form">
            <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
            <div class="form-group">
                <label for="email">Email Address</label>
                <input 
                    type="email" 
                    id="email" 
                    name="email" 
                    class="form-input" 
                    placeholder="Enter your email address"
                    autocomplete="email"
                    autofocus
                    required
                >
            </div>
            
            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-submit">
                    Send Reset Link
                </button>
            </div>
            
            <div style="text-align: center; margin-top: 20px;">
                <a href="/login" style="font-size: 0.9em; color: var(--text-color); opacity: 0.7; text-decoration: none;">Back to Login</a>
            </div>
        </form>
    </div>
</div>

{% endblock %}
