{% extends "dashboard.jinja2" %}

{% block title %}{{ ticket.id }} | {{ ticket.title }} | Broke{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dropdown.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/ticket.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/modal.css') }}">
    <!-- Quill.js -->
    <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
{% endblock %}

{% block path %}
    <a href="/tickets"><i class="ph ph-ticket"></i> Tickets</a> <i class="ph ph-caret-right"></i>
    {% if ticket.project == 'TRIAGE' %}
        <a href="/intake"><i class="ph ph-tray"></i> Intake</a>
    {% elif project %}
        <a href="/tickets/{{ project.id }}"><i class="{{ project.icon }}"></i> {{ project.name }}</a>
    {% else %}
        <a href="/tickets/{{ ticket.project }}"><i class="ph ph-folder-simple"></i> {{ ticket.project }}</a>
    {% endif %}
    <i class="ph ph-caret-right"></i> <a href="/tickets/{{ ticket.project }}/{{ ticket.id }}"><i class="ph ph-pen"></i> {{ ticket.id }}</a>
{% endblock %}

{% block content %}

<div class="ticket-top-actions" aria-label="Ticket actions">
    <a class="ticket-icon-action" href="/api/tickets/{{ ticket.id }}/export?format=markdown" title="Export markdown" aria-label="Export ticket as markdown" target="_blank" rel="noopener noreferrer">
        <i class="ph ph-file-text"></i>
    </a>
    <a class="ticket-icon-action" href="/api/tickets/{{ ticket.id }}/export?format=json" title="Export JSON" aria-label="Export ticket as JSON" target="_blank" rel="noopener noreferrer">
        <i class="ph ph-brackets-curly"></i>
    </a>
    <button class="ticket-icon-action ticket-icon-action-primary ticket-icon-action-labeled" type="button" title="Create subticket" aria-label="Create subticket" onclick="createSubticket()">
        <i class="ph ph-plus"></i>
        <span>New Subticket</span>
    </button>
</div>

<div id="ticket-editor"></div>

{% if parent_ticket or (subtickets and subtickets|length > 0) %}
<section class="ticket-subtickets-panel">
    <div class="ticket-subtickets-header">
        <div>
            <h3>Subtickets</h3>
            {% if parent_ticket %}
            <p>
                Parent:
                <a href="/tickets/{{ parent_ticket.project }}/{{ parent_ticket.id }}">{{ parent_ticket.id }}</a>
            </p>
            {% endif %}
            {% if subticket_count > 0 %}
            <p>
                <strong>Subticket Progress:</strong> {{ subticket_done_count }}/{{ subticket_count }} done
            </p>
            {% endif %}
        </div>
    </div>

    {% if all_subtickets_done and ticket.status not in ['done', 'closed'] %}
    <div class="ticket-subtickets-done-callout">
        <p><strong>All subtickets are complete</strong></p>
        <button class="btn btn-secondary" type="button" onclick="closeParentTicket()">
            <i class="ph ph-check-circle"></i> Close Parent Ticket
        </button>
    </div>
    {% endif %}

    {% if subtickets and subtickets|length > 0 %}
    <ul class="ticket-subtickets-list">
        {% for child in subtickets %}
        <li>
            <a href="/tickets/{{ child.project }}/{{ child.id }}"><strong>{{ child.id }}</strong></a>
            - {{ child.title }}
            <span>({{ child.status }}, {{ child.priority }})</span>
        </li>
        {% endfor %}
    </ul>
    {% endif %}
</section>
{% endif %}

{% endblock %}

{% block scripts %}
    <!-- Quill.js -->
    <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
    <!-- Agent comment markdown (GFM → HTML, then sanitized) -->
    <script src="https://cdn.jsdelivr.net/npm/marked@12.0.2/marked.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/dompurify@3.1.6/dist/purify.min.js"></script>
    <!-- Shared config -->
    <script src="{{ url_for('static', filename='js/config.js') }}"></script>
    <!-- Dropdown component -->
    <script src="{{ url_for('static', filename='js/dropdown.js') }}"></script>
    <!-- Ticket editor -->
    <script src="{{ url_for('static', filename='js/editor.js') }}"></script>

    <script src="{{ url_for('static', filename='js/modal.js') }}"></script>
    <script src="{{ url_for('static', filename='js/list_modal.js') }}"></script>

    <script>

        var editor;

        async function createSubticket() {
            try {
                const response = await fetch('/api/tickets', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        title: '',
                        description: '',
                        status: 'todo',
                        priority: 'medium',
                        project: '{{ ticket.project }}',
                        parent_ticket_id: '{{ ticket.id }}'
                    })
                });

                const payload = await response.json();
                if (!response.ok) {
                    alert(payload.error || 'Failed to create subticket');
                    return;
                }

                window.location.href = `/tickets/${payload.ticket.project}/${payload.ticket.id}`;
            } catch (error) {
                console.error('Create subticket error:', error);
                alert('Failed to create subticket');
            }
        }

        async function closeParentTicket() {
            if (!confirm('Close this parent ticket?')) return;

            try {
                const response = await fetch('/api/tickets/{{ ticket.id }}', {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ field: 'status', value: 'done' })
                });

                if (response.ok) {
                    window.location.reload();
                } else {
                    const payload = await response.json();
                    alert(payload.error || 'Failed to close ticket');
                }
            } catch (error) {
                console.error('Close ticket error:', error);
                alert('Failed to close ticket');
            }
        }

        function mountTopActionsInSidebar() {
            const actions = document.querySelector('.ticket-top-actions');
            const sidebar = document.querySelector('#ticket-editor .ticket-sidebar');
            if (!actions || !sidebar) return;

            const properties = sidebar.querySelector('.ticket-properties');
            if (properties) {
                properties.insertAdjacentElement('afterend', actions);
            } else {
                sidebar.appendChild(actions);
            }
        }

        function mountSubticketsInSidebar() {
            const subticketsPanel = document.querySelector('.ticket-subtickets-panel');
            const sidebar = document.querySelector('#ticket-editor .ticket-sidebar');
            if (!subticketsPanel || !sidebar) return;

            const actions = sidebar.querySelector('.ticket-top-actions');
            if (actions) {
                actions.insertAdjacentElement('afterend', subticketsPanel);
            } else {
                sidebar.appendChild(subticketsPanel);
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            // Sample ticket data (would come from backend)
            const ticketData = {
                id: '{{ ticket.id }}',
                title: '{{ ticket.title }}',
                description: `{{ ticket.description.replace("`", "\\`").replace("\n", "\\n") | safe }}`,
                status: '{{ ticket.status | default("todo", true) }}',
                priority: '{{ ticket.priority | default("medium", true) }}',
                error: { {% if ticket.error %}
                    id: '{{ ticket.error.id }}',
                    part: '{{ ticket.error.part.id }}',
                    project: '{{ ticket.error.part.project.id }}'
                {% else %}
                    id: null,
                    part: null,
                    project: null
                {% endif %}},
                labels: [
                    {% for label in ticket.labels %}
                    {
                        id: '{{ label.id }}',
                        name: '{{ label.name }}',
                        color: '{{ label.color }}'
                    },
                    {% endfor %}
                ],
                assignees: [
                    {% for assignee in ticket.assignees %}
                    {
                        id: '{{ assignee.username }}',
                        username: '{{ assignee.username }}',
                        avatar: null
                    },
                    {% endfor %}
                ],
                dueDate: '{{ ticket.due_date | default("", true) }}',
                workCycleId: {% if ticket.work_cycle_id is not none %}{{ ticket.work_cycle_id }}{% else %}null{% endif %},
                aiDelegate: {% if ticket.ai_delegate %}true{% else %}false{% endif %}
            };

            const availableWorkCycles = [
                {% for c in available_work_cycles %}
                { id: {{ c.id }}, name: {{ c.name | tojson }} },
                {% endfor %}
            ];

            // Current user (would come from session)
            const currentUser = {
                id: '{{ user.username }}',
                username: '{{ user.username }}',
                name: '{{ user.username }}',
                avatar: null
            };

            // Sample activity (would come from backend)
            const activityData = [
                {% for comment in comments %}
                {
                    id: '{{ comment.id }}',
                    author: {
                        id: '{{ comment.user.username }}',
                        username: '{{ comment.user.username }}',
                        name: '{{ comment.user.username }}',
                        avatar: "<svg width='40' height='40' data-jdenticon-value='{{ comment.user.username }}'></svg>"
                    },
                    type: 'comment',
                    viaAgent: {% if comment.via_agent %}true{% else %}false{% endif %},
                    content: {{ comment.body | default("", true) | tojson }},
                    createdAt: {{ comment.created_at }} * 1000
                },
                {% endfor %}
                {% for update in updates %}
                {
                    id: '{{ update.id }}',
                    message: {{ update.message | default("", true) | tojson }},
                    icon : {{ (update.icon or 'ph ph-pencil') | tojson }},
                    createdAt: {{ update.created_at }} * 1000,
                    type: 'update',
                    viaAgent: {% if '(agent)' in (update.message or '') %}true{% else %}false{% endif %}
                },
                {% endfor %}
            ]

            // Available options for dropdowns
            const availableUsers = [
                {% for available_user in available_users %}
                {
                    id: '{{ available_user.username }}',
                    username: '{{ available_user.username }}',
                },
                {% endfor %}
            ]

            const availableLabels = [
                {% for available_label in available_labels %}
                {
                    id: '{{ available_label.name }}',
                    name: '{{ available_label.name }}',
                    color: '{{ available_label.color }}'
                },
                {% endfor %}
            ]

            // Initialize ticket editor
            editor = new TicketEditor('ticket-editor', {
                ticket: ticketData,
                currentUser: currentUser,
                activity: activityData,
                availableUsers: availableUsers,
                availableLabels: availableLabels,
                availableWorkCycles: availableWorkCycles,

                // Save callback - POST to backend
                onSave: async (field, value, oldValue) => {
                    console.log('Saving:', field, value);
                    try {
                        const response = await fetch('/api/tickets/{{ ticket.id }}', {
                            method: 'PATCH',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ field, value, oldValue })
                        });

                        if (!response.ok) {
                            console.error('Failed to save:', await response.json());
                        }
                    } catch (error) {
                        console.error('Save error:', error);
                    }
                },

                // Comment callback - POST to backend
                onComment: async (content, comment) => {
                    console.log('New comment:', content);
                    try {
                        const response = await fetch('/api/tickets/{{ ticket.id }}/comments', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ content })
                        });

                        if (response.ok) {
                            const data = await response.json();
                            // Update comment with real ID from server
                            comment.id = data.comment.id;
                            if (typeof data.comment.via_agent === 'boolean') {
                                comment.viaAgent = data.comment.via_agent;
                            }
                        } else {
                            console.error('Failed to add comment:', await response.json());
                        }
                    } catch (error) {
                        console.error('Comment error:', error);
                    }
                },

                // Delete comment callback
                onDeleteComment: async (commentId) => {
                    console.log('Delete comment:', commentId);
                    try {
                        const response = await fetch(`/api/comments/${commentId}`, {
                            method: 'DELETE'
                        });

                        if (!response.ok) {
                            console.error('Failed to delete comment:', await response.json());
                        }
                    } catch (error) {
                        console.error('Delete comment error:', error);
                    }
                },

                // Edit comment callback
                onEditComment: (commentId, currentContent) => {
                    console.log('Edit comment:', commentId);
                    // Could open a modal or inline editor
                }
            });

            mountTopActionsInSidebar();
            mountSubticketsInSidebar();
        });
    </script>
{% endblock %}
