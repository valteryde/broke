{% extends "dashboard.jinja2" %}

{% block title %}Errors | Broke{% endblock %}

{% block head %}
    <link rel="stylesheet" href="{{ url_for('static', filename='css/dropdown.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/lists.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/modal.css') }}">
{% endblock %}

{% block path %}
    <a href="#" onclick="openUrlWithArgs('/errors'); return false;"><i class="ph ph-bug-beetle"></i> Errors</a>
{% endblock %}

{% block content %}

<h1>Parts</h1>
<p class="part-errors-description">Services and components that receive error events. Not tied to ticket projects.</p>

<div id="ticket-list"></div>

{% endblock %}

{% block scripts %}

    <script src="{{ url_for('static', filename='js/config.js') }}"></script>
    <script src="{{ url_for('static', filename='js/dropdown.js') }}"></script>
    <script src="{{ url_for('static', filename='js/modal.js') }}"></script>
    <script src="{{ url_for('static', filename='js/lists.js') }}"></script>
    <script src="{{ url_for('static', filename='js/list_modal.js') }}"></script>

    <script>
        function showCreatePartModal() {
            Modal.show('Create New Part', `
                <form id="create-part-form">
                    <div class="form-group">
                        <label for="part-name">Name</label>
                        <input type="text" id="part-name" name="name" placeholder="e.g. backend, frontend, api" required>
                    </div>
                    <div class="form-group">
                        <label for="part-description">Description</label>
                        <textarea id="part-description" name="description" placeholder="Describe this service or component..." rows="3"></textarea>
                    </div>
                    <div class="form-actions">
                        <button type="button" class="btn btn-secondary" onclick="Modal.close()">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Part</button>
                    </div>
                </form>
            `, {
                onOpen: (element) => {
                    const form = element.querySelector('#create-part-form');
                    form.addEventListener('submit', async (e) => {
                        e.preventDefault();

                        const name = document.getElementById('part-name').value.trim();
                        const description = document.getElementById('part-description').value.trim();

                        try {
                            const response = await fetch(brokeAppUrl('/api/parts'), {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ name, description })
                            });

                            const data = await response.json();

                            if (data.success) {
                                Modal.close();
                                window.location.href = brokeAppUrl(`/errors/${data.part.id}`);
                            } else {
                                alert(data.error || 'Failed to create part');
                            }
                        } catch (err) {
                            alert('Failed to create part');
                        }
                    });
                }
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const partList = new List('ticket-list', {
                filters: {
                    search: {
                        placeholder: 'Search parts...',
                        filter: (element, value) => {
                            if (!value) return true;
                            const searchText = `${element.title} ${element.description}`.toLowerCase();
                            return searchText.includes(value.toLowerCase());
                        }
                    },
                },
                groupBy: {
                },
                defaultGroupBy: 'none',
                onCreate: showCreatePartModal,
                onCreateLabel: 'New Part',
                renderer: (element) => {
                    const inner = document.createElement('div');
                    inner.className = 'list-element-inner';
                    inner.innerHTML = `
                        <i class="ph ${element.icon} list-element-icon"></i>
                        <span class="list-element-id">${element.id}</span>
                        <span class="list-element-text">
                            <h3>${element.title}</h3>
                            <p class="list-element-description">${element.description}</p>
                        </span>
                    `;
                    return inner;
                }
            });

            const partListItems = [
                {% for part in project_parts %}
                {
                    id: '{{ part.id }}',
                    title: '{{ part.name }}',
                    description: '{{ part.description | default("No description provided.", true) | safe }}',
                    icon: 'ph-puzzle-piece',
                    onClick: () => { window.location.href = '{{ request.script_root }}/errors/{{ part.id }}'; }
                },
                {% endfor %}
            ];

            partListItems.forEach(part => partList.add(part));
        });
    </script>

{% endblock %}
